---
import Button from "./UI/Button.astro";
---

<form>
    <div class="form-grid">
        <div class="form-group">
            <label for="name">Full name</label>
            <input type="text" id="name" name="name" placeholder="Jane Doe" required />
        </div>
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="jane@company.com" required />
        </div>

        <div class="form-group">
            <label for="organisation">Organization</label>
            <input type="text" id="organisation" name="organisation" placeholder="Institution or Company Name" />
        </div>
        <div class="form-group">
            <label for="object">Object</label>
            <input type="text" id="object" name="object" placeholder="Brief description of your project or inquiry" />
        </div>
    </div>

    <div class="form-group full-width">
        <label for="message">Project brief</label>
        <textarea id="message" name="message" placeholder="Please describe your technical requirements or current challenges..." required></textarea>
    </div>

    <div class="form-footer">
        <Button arrowIcon={true} title="Send" basic={false} icon="fa-solid fa-arrow-right" iconPosition="right"/>
    </div>
</form>

<style>
    form {
        background-color: var(--custom-white);
        border: 1px solid var(--border-color);
        border-radius: 24px;
        padding: 40px 50px 20px 50px;
        width: 100%;
        margin: 0 auto;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 32px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    input {
        padding: 12px 0;
        border-bottom: 1px solid var(--border-color);
        font-family: inherit;
        font-size: 1.2rem;
        color: var(--text-color);
        transition: all 0.3s ease;
    }

    textarea {
        padding: 12px 16px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        font-size: 1rem;
        font-family: inherit;
        background-color: var(--custom-white);
        color: var(--text-color);
        transition: all 0.3s ease;
    }

    input:focus {
        outline: none;
        border-bottom: 1px solid var(--primary-color);
    }

    textarea:focus {
        outline: none;
        border: 1px solid var(--primary-color);
    }
    
    textarea {
        min-height: 200px;
        resize: vertical;
    }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-top: 20px;
        padding-top: 24px;
    }

    @media(max-width: 768px) {
        form {
            padding: 24px;
        }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>