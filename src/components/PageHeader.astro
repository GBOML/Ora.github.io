---
import Badge from '../components/UI/Badge.astro';

interface Props {
    title: string;
    description: string;
    badgeText?: string;
}

const { title, description, badgeText } = Astro.props as Props;
---

<div class="header">
    {badgeText && <Badge text={badgeText}/>}
    <h1>
        {title}
    </h1>
    <p>
        {description}
    </p>
</div>

<style>
    .header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        margin-bottom: 50px;
    }

    h1 {
        font-size: 3rem;
        font-weight: bold;
        text-align: center;
    }

    p {
		color: var(--text-color-secondary);
		font-size: 1rem;
        text-align: center;
        max-width: 50%;
	}

    @media (max-width: 1024px) {
        .header {
        margin-top: 20px;

        }
    }
</style>